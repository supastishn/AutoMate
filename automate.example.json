{
  "agent": {
    "model": "claude-opus-4.6",
    "apiBase": "http://localhost:4141/v1",
    "systemPrompt": "You are AutoMate, a fast and capable personal AI assistant. You have access to tools for running shell commands, reading/writing files, browsing the web with an undetected Chrome browser, and more. Be concise and effective.",
    "maxTokens": 8192,
    "temperature": 0.3,
    "providers": [
      {
        "name": "openai-fallback",
        "model": "gpt-4o",
        "apiBase": "https://api.openai.com/v1",
        "apiKey": "",
        "priority": 10
      },
      {
        "name": "ollama-local",
        "model": "llama3",
        "apiBase": "http://localhost:11434/v1",
        "priority": 20
      }
    ],
    "subagent": {
      "defaultModel": "claude-sonnet-4.5",
      "useParentApiKey": true,
      "maxConcurrent": 3,
      "profiles": [
        {
          "name": "reviewer",
          "model": "claude-sonnet-4.5",
          "systemPrompt": "Focus on reliability, security, and edge cases.",
          "maxIterations": 40,
          "timeoutMs": 600000
        }
      ]
    }
  },
  "mcp": {
    "servers": [
      {
        "name": "filesystem",
        "enabled": false,
        "transport": "stdio",
        "command": "npx",
        "args": ["-y", "@modelcontextprotocol/server-filesystem", "~"],
        "env": {}
      }
    ]
  },
  "gateway": {
    "port": 18789,
    "host": "127.0.0.1",
    "auth": {
      "mode": "none"
    }
  },
  "channels": {
    "discord": {
      "enabled": false,
      "token": "",
      "allowFrom": ["*"]
    }
  },
  "browser": {
    "enabled": true,
    "engine": "playwright",
    "headless": false,
    "chromiumPath": "/usr/bin/chromium",
    "chromeDriverPath": "/usr/bin/chromedriver"
  },
  "skills": {
    "directory": "~/.automate/skills"
  },
  "sessions": {
    "directory": "~/.automate/sessions",
    "maxHistory": 200,
    "compactThreshold": 150
  },
  "canvas": {
    "enabled": true
  }
}
